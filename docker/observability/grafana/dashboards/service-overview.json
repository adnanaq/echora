{
  "id": null,
  "uid": "echora-service-overview",
  "title": "Echora Service Overview",
  "tags": [
    "echora",
    "observability",
    "red"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 3,
  "refresh": "15s",
  "templating": {
    "list": [
      {
        "name": "service_name",
        "type": "textbox",
        "label": "service_name",
        "query": "echora-.*",
        "current": {
          "text": "echora-.*",
          "value": "echora-.*"
        }
      },
      {
        "name": "env",
        "type": "textbox",
        "label": "env",
        "query": ".*",
        "current": {
          "text": ".*",
          "value": ".*"
        }
      }
    ]
  },
  "panels": [
    {
      "type": "timeseries",
      "title": "Request Rate (RPC)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(echora_vector_service_rpc_requests_total[5m]))",
          "legendFormat": "rps"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Error Rate (RPC)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(echora_vector_service_rpc_errors_total[5m])) / clamp_min(sum(rate(echora_vector_service_rpc_requests_total[5m])),1)",
          "legendFormat": "error_rate"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Latency P99 (RPC)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(echora_vector_service_rpc_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Request Rate by Method",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum by (rpc_method) (rate(echora_vector_service_rpc_requests_total[5m]))",
          "legendFormat": "logs/5m"
        }
      ]
    },
    {
      "type": "logs",
      "title": "Error Rate by Code",
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 16
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum by (error_code) (rate(echora_vector_service_rpc_errors_total[5m]))"
        }
      ]
    }
  ]
}
