{
  "id": null,
  "uid": "echora-trace-journey",
  "title": "Echora Trace Journey",
  "tags": [
    "echora",
    "tempo",
    "traces"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "15s",
  "templating": {
    "list": [
      {
        "name": "service_name",
        "type": "textbox",
        "label": "service_name",
        "query": "echora-.*",
        "current": {
          "text": "echora-.*",
          "value": "echora-.*"
        }
      }
    ]
  },
  "panels": [
    {
      "type": "timeseries",
      "title": "RPC Request Rate",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(echora_vector_service_rpc_requests_total[5m]))",
          "legendFormat": "spans_received"
        }
      ]
    },
    {
      "type": "logs",
      "title": "RPC Latency P95 by Method",
      "gridPos": {
        "h": 12,
        "w": 24,
        "x": 0,
        "y": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(echora_vector_service_rpc_duration_seconds_bucket[5m])) by (le, rpc_method))"
        }
      ]
    }
  ]
}
