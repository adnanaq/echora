{
  "id": null,
  "uid": "echora-vector-service-overview",
  "title": "Echora Vector Service Overview",
  "tags": [
    "echora",
    "vector",
    "service"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 8,
  "refresh": "15s",
  "panels": [
    {
      "type": "timeseries",
      "title": "RPC Request Rate",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(echora_rpc_requests_total{exported_job=\"echora-vector-service\"}[5m]))",
          "legendFormat": "requests/s"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      }
    },
    {
      "type": "timeseries",
      "title": "RPC Error Rate",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(echora_rpc_errors_total{exported_job=\"echora-vector-service\"}[5m])) / clamp_min(sum(rate(echora_rpc_requests_total{exported_job=\"echora-vector-service\"}[5m])),1)",
          "legendFormat": "error_ratio"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      }
    },
    {
      "type": "timeseries",
      "title": "RPC Latency P95 by Method",
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(echora_rpc_duration_seconds_bucket{exported_job=\"echora-vector-service\"}[5m])) by (le, rpc_method))",
          "legendFormat": "{{rpc_method}}"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      }
    },
    {
      "type": "timeseries",
      "title": "RPC Request Rate by Method",
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 18
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum by (rpc_method) (rate(echora_rpc_requests_total{exported_job=\"echora-vector-service\"}[5m]))",
          "legendFormat": "{{rpc_method}}"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      }
    },
    {
      "type": "timeseries",
      "title": "RPC Errors by Code",
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 18
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum by (error_code) (rate(echora_rpc_errors_total{exported_job=\"echora-vector-service\"}[5m]))",
          "legendFormat": "{{error_code}}"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      }
    },
    {
      "type": "row",
      "title": "Embedding Performance",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 27
      },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "gauge",
      "title": "Embedding Cache Hit Ratio",
      "description": "Percentage of embedding lookups served from Redis cache. Higher is better — each hit avoids a model inference call.",
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 0,
        "y": 28
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(echora_embedding_cache_total{result=\"hit\"}[$__rate_interval])) / clamp_min(sum(rate(echora_embedding_cache_total[$__rate_interval])),1)",
          "legendFormat": "hit_ratio"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.5 },
              { "color": "green", "value": 0.8 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      }
    },
    {
      "type": "timeseries",
      "title": "Embedding Cache Lookup Rate",
      "description": "Cache lookup rate broken down by result (hit/miss) and modality (text/image). Shows cache interactions per second. Helps identify if a particular modality has poor cache utilization.",
      "gridPos": {
        "h": 8,
        "w": 18,
        "x": 6,
        "y": 28
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum by (result, modality) (rate(echora_embedding_cache_total[$__rate_interval]))",
          "legendFormat": "{{modality}} {{result}}"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "fillOpacity": 20,
            "stacking": { "mode": "none" },
            "drawStyle": "line",
            "lineWidth": 2
          }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Embedding Inference Duration P95",
      "description": "P95 model inference latency by modality. This measures only the ML model call, excluding cache lookups. Text (BGE-M3) and image (OpenCLIP) are shown separately.",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 36
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(echora_embedding_duration_seconds_bucket[5m])) by (le, modality))",
          "legendFormat": "p95 {{modality}}"
        },
        {
          "expr": "histogram_quantile(0.50, sum(rate(echora_embedding_duration_seconds_bucket[5m])) by (le, modality))",
          "legendFormat": "p50 {{modality}}"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "fillOpacity": 10
          }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Cache Operation Duration P95",
      "description": "P95 Redis cache operation latency by operation type (get, set, get_batch, set_batch). High values indicate Redis latency issues separate from model inference.",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 36
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(echora_cache_operation_duration_seconds_bucket[5m])) by (le, operation))",
          "legendFormat": "p95 {{operation}}"
        },
        {
          "expr": "histogram_quantile(0.50, sum(rate(echora_cache_operation_duration_seconds_bucket[5m])) by (le, operation))",
          "legendFormat": "p50 {{operation}}"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "fillOpacity": 10
          }
        }
      }
    }
  ],
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {}
}
